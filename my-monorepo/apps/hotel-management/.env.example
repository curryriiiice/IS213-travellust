# Hotel Management Services Environment Variables

# 🔑 SerpApi Configuration
# Get your API key from: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# 🏠 Supabase Configuration
# Get your project URL from Supabase dashboard
SUPABASE_URL=https://your-project-id.supabase.co
# Get your anon/public key from Supabase dashboard
SUPABASE_KEY=your_supabase_anon_key_here

# 🚀 Service Configuration (usually not needed for Docker)
# SEARCH_SERVICE_URL=http://hotel-search-wrapper:5000
# SAVED_HOTELS_SERVICE_URL=http://saved-hotels:5000

# 💡 Setup Instructions:
# 1. Replace the values above with your actual credentials
# 2. Rename this file to .env
# 3. Run: ./docker-start.sh or docker-compose up --build
